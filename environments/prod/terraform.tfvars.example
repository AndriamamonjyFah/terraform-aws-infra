# terraform.tfvars.example — PROD
# !! Ne jamais commiter terraform.tfvars en production !!
# Utiliser des secrets GitHub Actions ou AWS Secrets Manager pour les valeurs sensibles.

project_name        = "my-infra"
aws_region          = "eu-west-3"
owner               = "team-infra"
github_username     = "your-username"

# Réseau  CIDR dédie prod
vpc_cidr            = "10.2.0.0/16"
subnet_public_cidr  = "10.2.1.0/24"

# EC2 — instance adaptée a la charge prod
instance_type       = "t3.medium"
root_volume_size    = 40
cpu_alarm_threshold = 70

# Securité  SSH OBLIGATOIREMENT restreint en prod
# Obtenir son IP : curl ifconfig.me
ssh_allowed_cidr    = "VOTRE_IP/32"
ssh_public_key_path = "~/.ssh/terraform_vm_key.pub"

# EBS optimized  disponible sur t3.medium
ebs_optimized       = true
